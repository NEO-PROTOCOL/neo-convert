# ─────────────────────────────────────────────────────────────
# NeoConvert — Variáveis de Ambiente
# Copie este arquivo: cp .env.example .env.local
# ─────────────────────────────────────────────────────────────

# ── FLOWPAY API (Checkout Pix centralizado na stack NEO) ─────
# Endpoint canônico do backend de pagamentos
FLOWPAY_API_URL=https://api.flowpay.cash
# API key interna do FlowPay (x-api-key para /api/create-charge)
FLOWPAY_INTERNAL_API_KEY=
#
# Opcional: mapear cada plano para product/button id da FlowPay (ex.: btn_xxx)
# FLOWPAY_PRODUCT_ID_STARTER=
# FLOWPAY_PRODUCT_ID_PRO=
# FLOWPAY_PRODUCT_ID_BUSINESS=
#
# Não usar estes segredos para checkout (são para validação de webhook):
# FLOWPAY_SIGNATURE_SECRET=
# FLOWPAY_WEBHOOK_SECRET=

# ── MAILTRAP (Email transacional) ─────────────────────────────
# Obter em: https://mailtrap.io → Email Sending → API Tokens
MAILTRAP_API_TOKEN=
MAILTRAP_CHECKOUT_PENDING_TEMPLATE_ID=
MAILTRAP_WELCOME_TEMPLATE_ID=
MAILTRAP_PAYMENT_SUCCESS_TEMPLATE_ID=
MAILTRAP_PASSWORD_RESET_TEMPLATE_ID=

# Remetente (deve estar verificado no Mailtrap para produção)
MAILTRAP_FROM_EMAIL=team@neo-convert.site
MAILTRAP_FROM_NAME=NeoConvertTeam

# ── APP ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── VERCEL BLOB (Upload de arquivos) ───────────────────────────
BLOB_READ_WRITE_TOKEN=
# Alias legado aceito pelo backend
# neo_READ_WRITE_TOKEN=

# Security Secret for Cron Jobs (minimum 32 characters)
CRON_SECRET=

# Security Secret for Download Tokens (minimum 32 characters, REQUIRED)
# Generate with: openssl rand -hex 32
DOWNLOAD_TOKEN_SECRET=
